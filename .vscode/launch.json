    "version": "0.2.0",
    "configurations": [
        {
            "name": "cms_app",
            "cwd": "examples/cms_app",
            "request": "launch",
            "type": "dart",
            "args": [
                "--web-port",
                "60366"
            ]
        },
        {
            "name": "CMS App (Chrome)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "deviceId": "chrome",
            "args": [
                "--web-port=60366",
                "--web-browser-flag=--user-data-dir=/tmp/flutter_cms_chrome_profile"
            ]
        },
        {
            "name": "CMS QA Test (Chrome)",
            "type": "dart",
            "request": "launch",
            "cwd": "examples/cms_app",
            "program": "lib/main_test.dart",
        }
    ]
}